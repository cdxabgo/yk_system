<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yk.system.mapper.AbnormalHeartRateMapper">

    <resultMap id="AbnormalHeartRateMap" type="AbnormalHeartRate">
        <id column="id" property="id"/>
        <result column="emp_id" property="empId"/>
        <result column="heart_rate" property="heartRate"/>
        <result column="measure_time" property="measureTime"/>
        <result column="alert_level" property="alertLevel"/>
        <result column="handle_status" property="handleStatus"/>
        <result column="create_time" property="createTime"/>
        <result column="emp_name" property="empName"/>
        <result column="emp_no" property="empNo"/>
    </resultMap>

    <select id="list" resultMap="AbnormalHeartRateMap">
        SELECT ahr.*, e.name AS emp_name, e.emp_no
        FROM abnormal_heart_rate ahr
        LEFT JOIN employee e ON ahr.emp_id = e.id
        <where>
            <if test="empId != null">
                AND ahr.emp_id = #{empId}
            </if>
            <if test="alertLevel != null and alertLevel != ''">
                AND ahr.alert_level = #{alertLevel}
            </if>
            <if test="handleStatus != null and handleStatus != ''">
                AND ahr.handle_status = #{handleStatus}
            </if>
        </where>
        ORDER BY ahr.measure_time DESC
    </select>

    <select id="getById" resultMap="AbnormalHeartRateMap">
        SELECT ahr.*, e.name AS emp_name, e.emp_no
        FROM abnormal_heart_rate ahr
        LEFT JOIN employee e ON ahr.emp_id = e.id
        WHERE ahr.id = #{id}
    </select>

    <insert id="insert" parameterType="AbnormalHeartRate" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO abnormal_heart_rate (emp_id, heart_rate, measure_time, alert_level, handle_status)
        VALUES (#{empId}, #{heartRate}, #{measureTime}, #{alertLevel}, #{handleStatus})
    </insert>

    <delete id="deleteById">
        DELETE FROM abnormal_heart_rate WHERE id = #{id}
    </delete>

</mapper>
