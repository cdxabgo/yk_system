<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yk.system.mapper.EmployeeMapper">

    <resultMap id="EmployeeMap" type="Employee">
        <id column="id" property="id"/>
        <result column="name" property="name"/>
        <result column="age" property="age"/>
        <result column="position" property="job"/>
        <result column="phone" property="contactInformation"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
    </resultMap>

    <select id="list" resultMap="EmployeeMap">
        SELECT id, name, age, position, phone, create_time, update_time
        FROM employee
        <where>
            <if test="name != null and name != ''">
                AND name LIKE CONCAT('%', #{name}, '%')
            </if>
            <if test="job != null and job != ''">
                AND position LIKE CONCAT('%', #{job}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="getById" resultMap="EmployeeMap">
        SELECT id, name, age, position, phone, create_time, update_time
        FROM employee WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="Employee" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO employee (name, age, position, phone)
        VALUES (#{name}, #{age}, #{job}, #{contactInformation})
    </insert>

    <update id="update" parameterType="Employee">
        UPDATE employee
        <set>
            <if test="name != null and name != ''">name = #{name},</if>
            <if test="age != null">age = #{age},</if>
            <if test="job != null">position = #{job},</if>
            <if test="contactInformation != null">phone = #{contactInformation},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM employee WHERE id = #{id}
    </delete>

</mapper>
