<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yk.system.mapper.HeartRateMapper">

    <resultMap id="HeartRateMap" type="HeartRate">
        <id column="id" property="id"/>
        <result column="emp_id" property="empId"/>
        <result column="heart_rate" property="heartRate"/>
        <result column="measure_time" property="measureTime"/>
        <result column="status" property="status"/>
        <result column="create_time" property="createTime"/>
        <result column="emp_name" property="empName"/>
        <result column="emp_no" property="empNo"/>
        <result column="department" property="department"/>
    </resultMap>

    <select id="list" resultMap="HeartRateMap">
        SELECT hr.*, e.name AS emp_name, e.emp_no, e.department
        FROM heart_rate hr
        LEFT JOIN employee e ON hr.emp_id = e.id
        <where>
            <if test="empId != null">
                AND hr.emp_id = #{empId}
            </if>
            <if test="status != null and status != ''">
                AND hr.status = #{status}
            </if>
            <if test="startTime != null and startTime != ''">
                AND hr.measure_time >= #{startTime}
            </if>
            <if test="endTime != null and endTime != ''">
                AND hr.measure_time &lt;= #{endTime}
            </if>
        </where>
        ORDER BY hr.measure_time DESC
    </select>

    <select id="getById" resultMap="HeartRateMap">
        SELECT hr.*, e.name AS emp_name, e.emp_no, e.department
        FROM heart_rate hr
        LEFT JOIN employee e ON hr.emp_id = e.id
        WHERE hr.id = #{id}
    </select>

    <insert id="insert" parameterType="HeartRate" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO heart_rate (emp_id, heart_rate, measure_time, status)
        VALUES (#{empId}, #{heartRate}, #{measureTime}, #{status})
    </insert>

    <delete id="deleteById">
        DELETE FROM heart_rate WHERE id = #{id}
    </delete>

    <delete id="deleteByEmpId">
        DELETE FROM heart_rate WHERE emp_id = #{empId}
    </delete>

</mapper>
