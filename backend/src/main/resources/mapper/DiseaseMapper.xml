<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.yk.system.mapper.DiseaseMapper">

    <resultMap id="DiseaseMap" type="Disease">
        <id column="id" property="id"/>
        <result column="disease_name" property="diseaseName"/>
        <result column="disease_type" property="diseaseType"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <select id="list" resultMap="DiseaseMap">
        SELECT * FROM disease
        <where>
            <if test="diseaseName != null and diseaseName != ''">
                AND disease_name LIKE CONCAT('%', #{diseaseName}, '%')
            </if>
            <if test="diseaseType != null and diseaseType != ''">
                AND disease_type LIKE CONCAT('%', #{diseaseType}, '%')
            </if>
        </where>
        ORDER BY create_time DESC
    </select>

    <select id="getById" resultMap="DiseaseMap">
        SELECT * FROM disease WHERE id = #{id}
    </select>

    <insert id="insert" parameterType="Disease" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO disease (disease_name, disease_type)
        VALUES (#{diseaseName}, #{diseaseType})
    </insert>

    <update id="update" parameterType="Disease">
        UPDATE disease
        <set>
            <if test="diseaseName != null and diseaseName != ''">disease_name = #{diseaseName},</if>
            <if test="diseaseType != null">disease_type = #{diseaseType},</if>
        </set>
        WHERE id = #{id}
    </update>

    <delete id="deleteById">
        DELETE FROM disease WHERE id = #{id}
    </delete>

</mapper>
